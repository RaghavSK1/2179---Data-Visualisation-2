{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 800,
  "height": 800,
  "projection": {
    "type": "mercator"
  },
  "layer": [
    {
      "description": "Base layer: NRM Regions",
      "data": {
        "url": "gbr_map_topojson.json",
        "format": {
          "type": "topojson",
          "feature": "NRM_Terrestrial_and_Marine_Regions_GBR_GDA2020_0_4650415230811652790"
        }
      },
      "mark": {
        "type": "geoshape",
        "fill": "#e0e0e0",
        "stroke": "white",
        "strokeWidth": 1
      }
    },
    {
      "description": "Base layer: Reef Features",
      "data": {
        "url": "gbr_map_topojson.json",
        "format": {
          "type": "topojson",
          "feature": "ALL REEFS - Great_Barrier_Reef_Features_20_-4783920091376539044"
        }
      },
      "mark": {
        "type": "geoshape",
        "fill": "#b2d8d8",
        "stroke": "#ffffff",
        "strokeWidth": 0.2
      }
    },
    {
      "description": "Data layer: Most Recent Manta Tow Survey per Reef",
      "data": {
        "url": "manta-tow-by-reef.csv"
      },
      "transform": [
        {
          "window": [
            {
              "op": "rank",
              "as": "latest_rank"
            }
          ],
          "sort": [
            {
              "field": "REPORT_YEAR",
              "order": "descending"
            }
          ],
          "groupby": ["REEF_ID"]
        },
        {
          "filter": "datum.latest_rank == 1"
        }
      ],
      "mark": {
        "type": "circle",
        "size": 40,
        "opacity": 0.9,
        "stroke": "black",
        "strokeWidth": 0.5
      },
      "encoding": {
        "longitude": {
          "field": "LONGITUDE",
          "type": "quantitative"
        },
        "latitude": {
          "field": "LATITUDE",
          "type": "quantitative"
        },
        "color": {
          "field": "MEAN_LIVE_CORAL",
          "type": "quantitative",
          "scale": {"scheme":"redyellowgreen"},
          "title": "Mean Live Coral %"
        },
        "tooltip": [
          {"field": "REEF_NAME", "type": "nominal", "title": "Reef Name"},
          {"field": "REEF_ID", "type": "nominal", "title": "Reef ID"},
          {"field": "REPORT_YEAR", "type": "nominal", "title": "Most Recent Survey Year"},
          {"field": "MEAN_LIVE_CORAL", "type": "quantitative", "title": "Live Coral (%)"}
        ]
      }
    }
  ]
}